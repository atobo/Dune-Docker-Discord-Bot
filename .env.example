# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GUILD_ID=your_discord_guild_id_here
CHANNEL_ID=your_discord_channel_id_for_messages

# PostgreSQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=15432
DB_USER=dune
DB_PASSWORD=your_db_password_here
DB_NAME=dune
DB_SCHEMA=dune

# RabbitMQ / AMQP Configuration
# The game's RabbitMQ typically runs on port 31982
RABBITMQ_URL=amqp://dune:your_rmq_password_here@127.0.0.1:31982

# Set to true to execute commands via docker exec rabbitmqctl instead of AMQP connection
USE_CLI_FALLBACK=true

# Log Configuration
# Option A: Tail the logs directly from the Docker container name (Recommended)
# To find your active containers on the server host, run `docker ps`
# In your setup, 'dune-server-survival-1' is the active survival instance container.
LOG_CONTAINER_NAME=dune-server-survival-1

# RabbitMQ container name for CLI fallback mode (if USE_CLI_FALLBACK=true)
RABBITMQ_CONTAINER_NAME=dune-rmq-game

# Option B: Path to the server log file (e.g. DuneSandbox.log) if not using Option A
# Note: Since this path is inside /root, the bot must run with root/sudo permissions to read it.
# LOG_FILE_PATH=/root/dune-awakening-selfhost-docker/runtime/game/survival-1/Saved/Logs/DuneSandbox_PIDX-1.log

# HTTP API Configuration (for Mobile Application)
API_PORT=3005
API_AUTH_TOKEN=your_secure_api_token_here
